# Copy this file to .env.local and fill in your values (for Vite/frontend)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# For blog import script (npm run blog:import) - get from Supabase Dashboard → Project Settings → API
# SUPABASE_SERVICE_ROLE_KEY=

# Supabase Edge Function secrets (configure in Supabase Dashboard → Project Settings → Edge Functions)
# CRM_WEBHOOK_URL - URL for CRM lead webhook (sync-lead-to-crm)
# WEBSITE_LEAD_API_KEY - API key for CRM webhook auth
# ZAPIER_WEBHOOK_URL - Zapier catch URL for waitlist (queue-webhook)
# ZAPIER_DESTINATION_EMAIL - Email destination for waitlist Zapier (queue-webhook)
